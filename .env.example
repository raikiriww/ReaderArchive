# Copy this file to .env before starting Reader Archive.
#
# On macOS/Linux, set these to your local user and group:
#   id -u
#   id -g

READER_API_PORT=38165
READER_IMAGE=ghcr.io/raikiriww/readerarchive:latest
READER_POSTGRES_DB=reader
READER_POSTGRES_USER=reader
READER_POSTGRES_PASSWORD=change-this-database-password
READER_SECRET_KEY=change-this-reader-secret-key

READER_BOOTSTRAP_ADMIN_USERNAME=admin
READER_BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
READER_SESSION_DAYS=30
READER_COOKIE_SECURE=false

READER_BROWSER_WAIT_DELAY_MS=2000
READER_BROWSER_LOAD_MAX_TIME_MS=20000
READER_BROWSER_CAPTURE_MAX_TIME_MS=60000
READER_ARCHIVE_TIMEOUT_SECONDS=120
READER_VIDEO_DOWNLOAD_TIMEOUT_SECONDS=600
READER_RSS_REFRESH_INTERVAL_SECONDS=1800
READER_RSS_REQUEST_TIMEOUT_SECONDS=20
READER_SEMANTIC_SEARCH_ENABLED=true

# Local folders mounted into the container.
READER_APP_DATA_DIR=./data
READER_ARCHIVE_DIR=./data/archive
READER_BROWSER_PROFILE_DIR=./data/browser/config
READER_POSTGRES_DIR=./data/postgres

READER_DESKTOP_PUID=1000
READER_DESKTOP_PGID=1000
