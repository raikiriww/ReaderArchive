+async function getExistingTarget(targetId) {
+	const response = await fetch(browserApiUrl + "/json/list");
+	if (!response.ok) {
+		throw new Error("Unable to list browser targets");
+	}
+	const targets = await response.json();
+	const target = targets.find(value => value.id === targetId && value.type === "page");
+	if (!target) {
+		throw new Error("Browser target not found: " + targetId);
+	}
+	return target;
