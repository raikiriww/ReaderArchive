#!/bin/bash
set -euo pipefail

BIN=/usr/bin/google-chrome
PROFILE_DIR="${READER_BROWSER_PROFILE_DIR:-/config/.config/reader-archive-profile}"
mkdir -p "${PROFILE_DIR}"

# Only clear leftover locks before the first Chrome process starts. Active
# Singleton files protect the profile from being opened twice.
if ! pgrep -f "/opt/google/chrome/chrome|/usr/bin/google-chrome" > /dev/null; then
  rm -f "${PROFILE_DIR}"/Singleton*
fi

exec "${BIN}" \
  --no-first-run \
  --no-sandbox \
  --remote-debugging-address=127.0.0.1 \
  --remote-debugging-port=9222 \
  --password-store=basic \
  --simulate-outdated-no-au='Tue, 31 Dec 2099 23:59:59 GMT' \
  --start-maximized \
  --test-type \
  --user-data-dir="${PROFILE_DIR}" \
  "$@" > /tmp/wrapped-chrome.log 2>&1
